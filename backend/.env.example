# PostgreSQL (default): create database "derby" first, then run migrations/seed
# SQLite (alternative): sqlite+aiosqlite:///./derby.db
DATABASE_URL=postgresql+asyncpg://postgres@127.0.0.1:5432/derby
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENTRY_COST_TOKENS=10
STARTING_TOKENS=100
WINNER_BONUS_TOKENS=50
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
