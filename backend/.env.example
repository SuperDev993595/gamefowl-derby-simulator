# SQLite (default) or PostgreSQL: postgresql+asyncpg://user@host:5432/derby
DATABASE_URL=sqlite+aiosqlite:///./derby.db
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENTRY_COST_TOKENS=10
STARTING_TOKENS=100
WINNER_BONUS_TOKENS=50
# Prize tiers: entry cost and winner bonus
ENTRY_COST_STANDARD=10
ENTRY_COST_GRAND=25
ENTRY_COST_PRESTIGIOUS=50
WINNER_BONUS_STANDARD=50
WINNER_BONUS_GRAND=150
WINNER_BONUS_PRESTIGIOUS=300
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Optional: Google SSO (set all three to enable "Sign in with Google")
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback
